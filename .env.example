# Backend Next.js + Supabase (endpoints públicos de checkout). Sin barra final.
NEXT_PUBLIC_API_BASE_URL=https://brosandsubs-monorepo-production.up.railway.app

# Modo de checkout Wompi: 'widget' (modal JS) o 'redirect' (Web Checkout).
NEXT_PUBLIC_WOMPI_CHECKOUT_MODE=redirect

# Número de WhatsApp del negocio (CTA "volver a WhatsApp"). Opcional.
NEXT_PUBLIC_WA_BUSINESS_NUMBER=
